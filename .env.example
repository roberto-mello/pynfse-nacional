# Copy to .env and fill in. .env stays gitignored.
# Cert password stays in macOS Keychain:
#   security add-generic-password -a "cert-password" -s "pynfse-nacional-tests" -w

NFSE_TEST_CERT_PATH=/path/to/your-cert.pfx
NFSE_TEST_PRESTADOR_CNPJ=11222333000181
NFSE_TEST_PRESTADOR_IM=12345
# Set exactly one for successful homologacao issuance. The document must be
# registered in the recipient's Cadastro CPF/CNPJ.
NFSE_TEST_TOMADOR_CNPJ=
NFSE_TEST_TOMADOR_CPF=
NFSE_TEST_CODIGO_MUNICIPIO=
NFSE_TEST_CODIGO_LC116=04.01.01
NFSE_TEST_CODIGO_TRIBUTACAO_MUNICIPAL=100
# Optional override; leave empty to generate a unique DPS number per run.
NFSE_TEST_NUMERO_DPS=
